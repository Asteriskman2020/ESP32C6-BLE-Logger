<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Card View Style -->
    <style name="CardViewStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/colorCard</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">4dp</item>
    </style>

    <!-- Primary Command Button -->
    <style name="ButtonStyle.Command" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/colorButtonCmd</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <!-- Scan Button -->
    <style name="ButtonStyle.Scan" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/colorPrimary</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <!-- Outlined Disconnect Button -->
    <style name="ButtonStyle.Disconnect" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/colorPrimaryDark</item>
        <item name="android:textColor">@color/colorPrimaryDark</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <!-- Section Header Text -->
    <style name="TextStyle.SectionHeader">
        <item name="android:textColor">@color/colorPrimaryDark</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.08</item>
    </style>

    <!-- Sensor Value Text -->
    <style name="TextStyle.SensorValue">
        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Sensor Label Text -->
    <style name="TextStyle.SensorLabel">
        <item name="android:textColor">@color/textSecondary</item>
        <item name="android:textSize">14sp</item>
    </style>

</resources>
